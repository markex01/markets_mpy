# Ignore Jupyter notebook outputs, except .ipynb files
notebooks/**/*
!notebooks/**/
!notebooks/**/*.ipynb

handover


# Python cache and build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Notebook/tooling cache
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Project exports — ignore output contents, but keep the folder structure via .gitkeep placeholders
outputs/**
!outputs/**/
!outputs/**/.gitkeep

.env
data/temp/*
logs/*.log

# Ignore data contents, but keep the folder structure via .gitkeep placeholders
data/**
!data/**/
!data/**/.gitkeep
# Keep the finance reference data (actual files tracked)
!data/finance/
!data/finance/**