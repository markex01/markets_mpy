{
  "permissions": {
    "allow": [
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(pip install -e*)",
      "Bash(python -c*)",
      "Bash(jupyter lab*)",
      "Bash(conda activate*)",
      "Bash(conda info*)",
      "Bash(python --version)",
      "Bash(pip list*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(rm -rf*)",
      "Write(.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format \"$CLAUDE_TOOL_OUTPUT_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Claude] About to run: $CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      }
    ]
  }
}
